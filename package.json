{
  "name": "home-repair-platform",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "codegen": "turbo codegen",
    "typecheck": "pnpm codegen && turbo typecheck",
    "lint": "pnpm codegen && turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo test",
    "db:migrate": "pnpm --filter @home-repair/db db:migrate",
    "db:migrate:test": "pnpm --filter @home-repair/db db:migrate:test"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}
