# Copy to .env and fill in values
# Local Postgres (matches docker-compose.yml)
# One-time setup: createdb -U postgres home_repair
DATABASE_URL=postgres://postgres:postgres@localhost:5432/home_repair

# Test database — used by `pnpm test` (see .env.test, which is committed)
# One-time setup: createdb -U postgres home_repair_test && pnpm db:migrate:test
# TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/home_repair_test

# Supabase — create a project at supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API server
PORT=4000

# Web app (Vite requires VITE_ prefix for client-side vars)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=http://localhost:4000/graphql
